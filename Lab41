
import numpy as np
def simulate_coin_flips(n=5000):
    outcomes = np.random.choice(["H", "T"], size=n, p=[0.5, 0.5])
    return np.mean(outcomes == "H")  # Empirical P(Heads)
    return np.mean(outcomes == "T")  # Empirical P(Heads)

p_heads = simulate_coin_flips()  # ≈ 0.5
print("P(Heads) ≈", p_heads)

def simulate_die(n=10000):
    rolls = np.random.randint(1, 7, size=n)  # 1 to 6
    return np.mean(rolls % 2 == 0), np.mean(rolls >= 4)

p_even, p_ge4 = simulate_die()  # Both ≈ 0.5
